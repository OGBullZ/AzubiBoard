Options -Indexes

# ── HTTPS erzwingen ──────────────────────────────────────────
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteCond %{HTTP_HOST} !^localhost [NC]
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# ── Security-Headers (K3) ────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options    "nosniff"
    Header always set X-Frame-Options           "DENY"
    # X-XSS-Protection ist deprecated und kann in alten Browsern SCHADEN
    # (CSP übernimmt seine Aufgabe). Daher entfernt.
    Header always unset X-XSS-Protection

    Header always set Referrer-Policy           "strict-origin-when-cross-origin"
    Header always set Permissions-Policy        "geolocation=(), microphone=(), camera=(), payment=(), usb=(), fullscreen=(self), accelerometer=(), gyroscope=(), magnetometer=()"

    # Cross-Origin-Isolation (Spectre-Mitigation)
    Header always set Cross-Origin-Opener-Policy   "same-origin"
    Header always set Cross-Origin-Resource-Policy "same-origin"

    # CSP — verschärft:
    #   - 'unsafe-inline' für style bleibt (React inline-styles via style={{}})
    #   - 'unsafe-inline' für script ist NICHT mehr nötig (Vite-Bundle hat
    #     keine inline-Scripts mehr; nur src=, type=module)
    #   - connect-src: self + Sentry-Ingest + Lighthouse-CI-Tunnel (für Audits)
    #   - frame-ancestors 'none' ergänzt X-Frame-Options DENY
    #   - form-action 'self' verhindert exfiltrating-Forms
    #   - base-uri 'self' verhindert <base>-Tag-Hijacking
    #   - object-src 'none': keine Flash/Java-Plugins
    #   - upgrade-insecure-requests: http-Sub-Resources auf https hochheben
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' https://*.ingest.sentry.io https://*.sentry.io; manifest-src 'self'; worker-src 'self'; child-src 'self'; frame-ancestors 'none'; form-action 'self'; base-uri 'self'; object-src 'none'; upgrade-insecure-requests"

    # HSTS nur auf HTTPS (preload-ready: 1 Jahr + includeSubDomains)
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS

    # Statische Assets dürfen unter immutable cachen ausgeliefert werden
    <FilesMatch "\.(js|css|woff2|svg|png|webp)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    # SW darf NIE long-term gecacht werden (sonst kein Update)
    <FilesMatch "(sw|workbox.*)\.js$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>
</IfModule>

# ── .env und config nicht ausliefern ─────────────────────────
<FilesMatch "^\.env|composer\.(json|lock)|package(-lock)?\.json$">
    Require all denied
</FilesMatch>

# ── SPA-Routing: alles → index.html (außer api/ und echte Dateien) ──
RewriteEngine On
RewriteBase /azubiboard/
RewriteCond %{REQUEST_URI} !^/azubiboard/api/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [L]

# ── Cache-Header für statische Assets ────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html                 "access plus 0 seconds"
    ExpiresByType application/javascript    "access plus 1 year"
    ExpiresByType text/css                  "access plus 1 year"
    ExpiresByType image/svg+xml             "access plus 1 year"
    ExpiresByType image/png                 "access plus 1 year"
    ExpiresByType image/webp                "access plus 1 year"
    ExpiresByType font/woff2                "access plus 1 year"
</IfModule>
