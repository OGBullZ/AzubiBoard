# ── Frontend (Vite) ──────────────────────────────────────────
# true  = PHP-API verwenden (Produktion)
# false = localStorage verwenden (Entwicklung ohne Backend)
VITE_USE_API=false
VITE_API_BASE_URL=/api

# ── PHP Backend (api/config.php) ─────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=azubiboard
DB_USER=azubiboard_user
DB_PASS=SICHERES_PASSWORT_HIER

# WICHTIG: min. 32 zufällige Zeichen, NIEMALS committen!
# Generieren: openssl rand -hex 32
JWT_SECRET=AENDERN_openssl_rand_-hex_32

JWT_EXPIRY=604800   # 7 Tage in Sekunden

# Exakte Frontend-Domain (kein Wildcard in Produktion)
ALLOWED_ORIGIN=https://deine-domain.de

APP_ENV=production   # oder: development
