# ============================================================
#  AzubiBoard – Umgebungsvariablen
#  Kopieren: cp .env.example .env  →  .env NIEMALS committen!
# ============================================================

# ── Frontend (Vite) ──────────────────────────────────────────
# Unterpfad der App (XAMPP lokal: /azubiboard/  |  eigene Domain: /)
VITE_BASE_PATH=/azubiboard/

# true  = PHP-API + MySQL (Produktion / XAMPP)
# false = localStorage (reines Frontend, kein Backend nötig)
VITE_USE_API=true

# Wird automatisch aus VITE_BASE_PATH abgeleitet.
# Nur setzen wenn die API woanders liegt:
# VITE_API_BASE_URL=http://localhost/azubiboard/api

# Dev-Proxy: Vite → XAMPP PHP (nur bei npm run dev relevant)
VITE_PHP_DEV_URL=http://localhost

# Sentry-DSN (L3) — leer lassen wenn kein Error-Tracking gewünscht.
# Holen bei https://sentry.io → Project Settings → Client Keys (DSN).
# VITE_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/YYY
# VITE_APP_VERSION=1.0.0       # für Release-Tracking

# ── PHP Backend (api/config.php) ─────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=azubiboard
DB_USER=azubiboard_user
DB_PASS=HIER_DEIN_DB_PASSWORT

# JWT-Secret: min. 32 zufällige Zeichen — NIEMALS committen!
# Generieren mit: openssl rand -hex 32
JWT_SECRET=HIER_SICHERES_SECRET_EINTRAGEN

JWT_EXPIRY=604800

# Exakte Frontend-URL (kein Wildcard)
ALLOWED_ORIGIN=http://localhost

APP_ENV=development
