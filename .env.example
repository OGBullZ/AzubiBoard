# ============================================================
#  AzubiBoard – Umgebungsvariablen
#  Kopieren: cp .env.example .env  →  .env NIEMALS committen!
# ============================================================

# ── Frontend (Vite) ──────────────────────────────────────────
# Unterpfad der App (XAMPP lokal: /azubiboard/  |  eigene Domain: /)
VITE_BASE_PATH=/azubiboard/

# true  = PHP-API + MySQL (Produktion / XAMPP)
# false = localStorage (reines Frontend, kein Backend nötig)
VITE_USE_API=true

# Wird automatisch aus VITE_BASE_PATH abgeleitet.
# Nur setzen wenn die API woanders liegt:
# VITE_API_BASE_URL=http://localhost/azubiboard/api

# Dev-Proxy: Vite → XAMPP PHP (nur bei npm run dev relevant)
VITE_PHP_DEV_URL=http://localhost

# Sprint 12 L5 Schema-First: Wenn true, liest das Frontend aus den
# relationalen Endpoints statt aus dem Blob (/api/data).
# Setzt FORCE_SCHEMA=true im Backend voraus (sonst schreibt der
# Save-Queue weiter in den Blob).
# VITE_USE_SCHEMA=false

# Sentry-DSN (L3) — leer lassen wenn kein Error-Tracking gewünscht.
# Holen bei https://sentry.io → Project Settings → Client Keys (DSN).
# VITE_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/YYY
# VITE_APP_VERSION=1.0.0       # für Release-Tracking

# ── PHP Backend (api/config.php) ─────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=azubiboard
DB_USER=azubiboard_user
DB_PASS=HIER_DEIN_DB_PASSWORT

# JWT-Secret: min. 32 zufällige Zeichen — NIEMALS committen!
# Generieren mit: openssl rand -hex 32
JWT_SECRET=HIER_SICHERES_SECRET_EINTRAGEN

JWT_EXPIRY=604800

# Exakte Frontend-URL (kein Wildcard)
ALLOWED_ORIGIN=http://localhost

APP_ENV=development

# N1 (Sprint 13): SMTP für PHPMailer (weekly_digest.php).
# Leer lassen = PHP native mail() (braucht Postfix/Sendmail auf dem Server).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=azubiboard@example.com
# SMTP_PASS=DEIN_SMTP_PASSWORT
# SMTP_FROM=azubiboard@example.com
# SMTP_FROM_NAME=AzubiBoard
# SMTP_SECURE=tls   # tls (Port 587), ssl (Port 465), leer = kein TLS
# APP_URL=https://azubiboard.example.com   # Link in der Digest-Mail

# Sprint 12 L5-DEP: Wenn true, liefert POST /api/data 410 Gone.
# Nur aktivieren wenn VITE_USE_SCHEMA=true im Frontend-Build und
# alle relationalen Write-Pfade implementiert sind (Phase 4).
# FORCE_SCHEMA=false

# Sprint 12 L5-5: Dual-Write (Blob → relationale Tabellen, insert-only).
# Auf true setzen nach Phase 2, solange noch kein FORCE_SCHEMA.
# BACKEND_DUAL_WRITE=false
